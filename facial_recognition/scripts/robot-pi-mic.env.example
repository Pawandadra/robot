# Copy to ~/.config/robot-pi-mic.env and edit (used by laptop_pi_mic_tunnel.sh).
# chmod 600 ~/.config/robot-pi-mic.env   (optional)

ROBOT_PI_HOST=192.168.76.99
ROBOT_PI_PULSE_PORT=4713
# From Pi: pactl list sources short  (webcam line, 2nd column)
ROBOT_PI_MIC_SOURCE=alsa_input.usb-FINGERS_FINGERS_1080_Hi-Res_Webcam_20200803-02.mono-fallback
# Local Pulse source name for the tunnel (stable default for .env MIC_INDEX / default)
ROBOT_PI_MIC_LOCAL_NAME=robot_pi_webcam_mic

# --- Optional: play TTS on the Pi (speakers / 3.5 mm / HDMI) ---
# On Pi: pactl get-default-sink   OR   pactl list sinks short   (2nd column)
# ROBOT_PI_SINK=alsa_output.platform-bcm2835_audio-analog-stereo
# ROBOT_PI_SPEAKER_LOCAL_NAME=robot_pi_speaker
# Laptop tunnel sink gain (Pulse allows >100% = software boost). Try 150–200 if quiet.
ROBOT_PI_SPEAKER_VOLUME_PERCENT=150
