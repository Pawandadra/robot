## Copy this to `.env` (do not commit .env)

# --- Camera / mic ---
# Pi webcam on robot + processing on laptop:
#   Pi: run mjpg-streamer (or similar); set CAMERA_URL to its MJPEG URL, e.g.:
# Pi ustreamer: http://<pi-ip>:8080/stream   |   mjpg-streamer: http://<pi-ip>:8080/?action=stream
# CAMERA_URL=http://192.168.76.99:8080/stream
#   Pi mic → laptop: PulseAudio tunnel (PI_AND_LAPTOP_SIMPLE.md). With CAMERA_URL set,
#   the app prefers devices whose names contain "robot_pi" or "tunnel" (MIC_TUNNEL_HINTS).
#   Clear MIC_NAME_HINT unless you use a laptop USB mic named e.g. "fingers".
CAMERA_INDEX=2
ALLOW_CAMERA_FALLBACK=1
MIC_INDEX=17
MIC_NAME_HINT=
# Quiet / Pi tunnel: try MIC_MIN_ENERGY=50–70, MIC_AFTER_CALIB_MULT=0.35–0.45, MIC_AMBIENT_DURATION=0.25
# NAME_TIMEOUT=20, NAME_LISTEN_AFTER_TTS_SEC=1.0
# Comma-separated substrings to find the Pi Pulse tunnel (when CAMERA_URL is set):
# MIC_TUNNEL_HINTS=robot_pi,tunnel

# --- Local Q&A (answers in data/nora_faq.json; listening = Google STT, same as enrollment quality) ---
ENABLE_LOCAL_FAQ=1
# FAQ_JSON_PATH=
FAQ_POLL_INTERVAL_SEC=12
FAQ_COOLDOWN_AFTER_ANSWER_SEC=8
FAQ_GOOGLE_TIMEOUT=5
FAQ_GOOGLE_PHRASE_LIMIT=7
FAQ_GOOGLE_AMBIENT_SEC=0.12

# --- Face recognition ---
FACE_TOLERANCE=0.42
PROCESS_EVERY_N_FRAMES=3
FACE_ENCODING_JITTERS=2
FRAME_SCALE=0.5
FAR_FRAME_SCALE=0.75
MIN_FACE_SIZE=35
MIN_FAR_FACE_SIZE=24
FACE_DETECTION_MODEL=hog

# --- Greeting behavior ---
EXIT_RESET_SECONDS=5.0

# --- Enrollment / unknown ---
UNKNOWN_STREAK=2
UNKNOWN_COOLDOWN=15
ENROLLMENT_GRACE_PERIOD=30
ENROLLMENT_SAMPLES=3
ENROLLMENT_JITTERS=1
ENROLLMENT_FRAME_SLEEP_SEC=0.08
ENROLLMENT_MAX_TRIES=18
MIN_BLUR_SCORE=70

# --- STT (name input) ---
STT_ENGINE=google
SPEECH_LANGUAGE=en-IN
SPEECH_ALT_LANGUAGE=
MIC_AMBIENT_DURATION=0.1
NAME_TIMEOUT=15
NAME_PHRASE_TIME_LIMIT=10
NAME_LISTEN_AFTER_TTS_SEC=0.7
MIC_AFTER_CALIB_MULT=0.5

# Optional Vosk (offline)
VOSK_MODEL_PATH=/opt/vosk/models
VOSK_MAX_SECONDS=5.0
VOSK_SILENCE_TIMEOUT=1.5
VOSK_GRAMMAR=

# --- TTS (offline) ---
TTS_ENGINE=piper
PIPER_MODEL=/opt/piper/models/en_US-ryan-high.onnx
PIPER_LENGTH_SCALE=0.9
# paplay stream boost: 0=default; 65536=100%; ~98304≈150% (Pi tunnel only, optional)
# PAPLAY_VOLUME=98304
ESPEAK_VOICE=en
ESPEAK_WPM=150

# --- DB ---
DB_HOST=localhost
DB_USER=robot
DB_PASSWORD=
DB_NAME=robot

# --- Storage ---
FACE_FILES_DIR=data/faces

# --- Giga USB (HOLD/RUN over serial from the vision app; same process as face detection) ---
# Local: auto or /dev/ttyACM0. Remote Pi: socket://pi-ip:7000 and run scripts/pi_giga_tcp_bridge.py on the Pi.
# If the robot never stops: ensure user is in group "dialout", and GIGA_SERIAL_PORT is the Giga (see /dev/serial/by-id/).
ENABLE_GIGA=1
GIGA_DEBUG=0
GIGA_SERIAL_PORT=auto
GIGA_BAUD=115200
GIGA_BOOT_DELAY_SEC=2.0
# Re-send HOLD while a face is present (USB CDC can drop lines). Set 0 to disable.
GIGA_HOLD_PULSE_SEC=0.25
HOLD_PRESENT_STREAK=1
HOLD_ABSENT_STREAK=4
HOLD_POST_INTERACTION_GRACE_SEC=4.0
# Extra pause after TTS (robot stays in HOLD); tune in seconds
GREET_PAUSE_AFTER_KNOWN_SEC=1.5
GREET_PAUSE_AFTER_ENROLL_SEC=1.0
GREET_PAUSE_AFTER_GROUP_SEC=1.5
