## Copy this to `.env` (do not commit .env)

# --- Camera / mic ---
CAMERA_INDEX=2
ALLOW_CAMERA_FALLBACK=1
MIC_INDEX=1
MIC_NAME_HINT=fingers

# --- Face recognition ---
FACE_TOLERANCE=0.42
PROCESS_EVERY_N_FRAMES=3
FACE_ENCODING_JITTERS=2
FRAME_SCALE=0.5
FAR_FRAME_SCALE=0.75
MIN_FACE_SIZE=35
MIN_FAR_FACE_SIZE=24
FACE_DETECTION_MODEL=hog

# --- Greeting behavior ---
EXIT_RESET_SECONDS=5.0

# --- Enrollment / unknown ---
UNKNOWN_STREAK=2
UNKNOWN_COOLDOWN=15
ENROLLMENT_GRACE_PERIOD=30
ENROLLMENT_SAMPLES=5
MIN_BLUR_SCORE=70

# --- STT (name input) ---
STT_ENGINE=google
SPEECH_LANGUAGE=en-IN
SPEECH_ALT_LANGUAGE=
MIC_AMBIENT_DURATION=0.1
NAME_TIMEOUT=10
NAME_PHRASE_TIME_LIMIT=8

# Optional Vosk (offline)
VOSK_MODEL_PATH=/opt/vosk/models
VOSK_MAX_SECONDS=5.0
VOSK_SILENCE_TIMEOUT=1.5
VOSK_GRAMMAR=

# --- TTS (offline) ---
TTS_ENGINE=piper
PIPER_MODEL=/opt/piper/models/en_US-lessac-medium.onnx
PIPER_LENGTH_SCALE=0.9
ESPEAK_VOICE=en
ESPEAK_WPM=150

# --- DB ---
DB_HOST=localhost
DB_USER=robot
DB_PASSWORD=
DB_NAME=robot

# --- Storage ---
FACE_FILES_DIR=data/faces

